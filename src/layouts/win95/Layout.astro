---
import "../../styles/global.css";
import Taskbar from "../../components/win95/Taskbar.svelte";

interface Props {
  title?: string;
}

const { title = "Maxi Homepage" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="m-0 min-h-screen overflow-hidden">
    <slot />
    <Taskbar client:load />
  </body>
  <script>
    document.documentElement.classList.add('theme-win95');
  </script>
</html>
